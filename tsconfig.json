{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["node", "jest", "@testing-library/jest-dom"],
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": "./",
    "paths": {
      "@/icons/*": ["src/common/presentation/ui/decorative/icons/*"],
      "@/ui/*": ["./src/common/presentation/ui/*"],
      "@/landing/*": ["./src/module/landing/*"],
      "@/dashboard/*": ["./src/module/dashboard/*"],
      "@/user/*": ["./src/module/user/*"],
      "@/car/*": ["./src/module/car/*"],
      "@/common/*": ["./src/common/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "coverage/",
    "node_modules/",
    "playwright/",
    "playwright-report/",
    "resources/",
    "test-result/"
  ]
}
